{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codeslp.dev/cgraph/schemas/clusters.json",
  "title": "cgraph clusters response",
  "description": "Louvain community detection results over the structural and semantic code graph.",
  "type": "object",
  "required": [
    "ok",
    "kind",
    "schema_version",
    "communities",
    "edges",
    "cross_edges",
    "stats",
    "parameters",
    "advisories"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "kind": { "const": "clusters" },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "project": { "type": ["string", "null"] },
    "error": { "type": ["string", "null"] },
    "communities": {
      "type": "array",
      "items": { "$ref": "#/$defs/community" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "cross_edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/cross_edge" }
    },
    "stats": { "$ref": "#/$defs/stats" },
    "parameters": { "$ref": "#/$defs/parameters" },
    "advisories": {
      "type": "array",
      "items": { "$ref": "#/$defs/advisory" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "community": {
      "type": "object",
      "required": ["id", "size", "members"],
      "properties": {
        "id": { "type": "integer", "minimum": 0 },
        "size": { "type": "integer", "minimum": 0 },
        "members": {
          "type": "array",
          "items": { "$ref": "#/$defs/member" }
        }
      },
      "additionalProperties": false
    },
    "member": {
      "type": "object",
      "required": ["uid", "name", "path", "type"],
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "path": { "type": "string" },
        "type": { "type": "string" }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["source", "target", "type", "provenance", "confidence", "community"],
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "type": { "type": "string" },
        "provenance": { "type": "string" },
        "confidence": { "type": "number" },
        "community": { "type": "integer", "minimum": -1 }
      },
      "additionalProperties": false
    },
    "cross_edge": {
      "type": "object",
      "required": [
        "source",
        "target",
        "type",
        "provenance",
        "source_community",
        "target_community"
      ],
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "type": { "type": "string" },
        "provenance": { "type": "string" },
        "source_community": { "type": "integer", "minimum": 0 },
        "target_community": { "type": "integer", "minimum": 0 },
        "surprise": { "type": "number", "minimum": 0, "maximum": 10, "description": "Architectural surprise score (0=expected, 10=highly unexpected)." }
      },
      "additionalProperties": false
    },
    "stats": {
      "type": "object",
      "required": [
        "total_nodes",
        "total_edges",
        "communities",
        "structural_edges",
        "semantic_edges",
        "cross_community_edges"
      ],
      "properties": {
        "total_nodes": { "type": "integer", "minimum": 0 },
        "total_edges": { "type": "integer", "minimum": 0 },
        "communities": { "type": "integer", "minimum": 0 },
        "structural_edges": { "type": "integer", "minimum": 0 },
        "semantic_edges": { "type": "integer", "minimum": 0 },
        "cross_community_edges": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "parameters": {
      "type": "object",
      "required": ["semantic_threshold", "max_semantic_nodes"],
      "properties": {
        "semantic_threshold": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "max_semantic_nodes": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "advisory": {
      "type": "object",
      "required": ["level", "kind", "detail"],
      "properties": {
        "level": { "enum": ["warn", "info"] },
        "kind": { "type": "string", "enum": ["no_graph"] },
        "detail": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
