{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codeslp.dev/cgraph/schemas/audit.json",
  "title": "kkg audit response",
  "oneOf": [
    { "$ref": "#/$defs/audit_response" },
    { "$ref": "#/$defs/calibration_response" }
  ],
  "$defs": {
    "audit_response": {
      "type": "object",
      "required": ["kind", "standards_evaluated", "advisories", "counts", "hard_zero"],
      "properties": {
        "ok": { "type": "boolean" },
        "kind": { "type": "string", "enum": ["audit", "audit_list", "audit_explain"] },
        "scope": { "type": "string" },
        "scope_source": { "type": "string", "enum": ["all", "git", "explicit_files"] },
        "files_requested": { "type": "integer", "minimum": 0 },
        "standards_evaluated": { "type": "integer" },
        "advisories": {
          "type": "array",
          "items": { "$ref": "#/$defs/advisory" }
        },
        "counts": {
          "type": "object",
          "properties": {
            "warn": { "type": "integer" },
            "hard": { "type": "integer" }
          }
        },
        "hard_zero": { "type": "boolean" },
        "error": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "calibration_response": {
      "type": "object",
      "required": ["kind", "rules_analyzed", "rules"],
      "properties": {
        "ok": { "type": "boolean" },
        "kind": { "type": "string", "const": "audit_calibration" },
        "rules_analyzed": { "type": "integer" },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/calibration_rule" }
        },
        "error": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "advisory": {
      "type": "object",
      "required": ["kind", "severity", "standard_id", "offenders"],
      "properties": {
        "kind": { "type": "string" },
        "severity": { "type": "string", "enum": ["warn", "hard"] },
        "standard_id": { "type": "string" },
        "threshold_applied": { "type": "object" },
        "offenders": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["uid", "name", "path"],
            "properties": {
              "uid": { "type": "string" },
              "name": { "type": ["string", "null"] },
              "path": { "type": ["string", "null"] },
              "line_number": { "type": ["integer", "null"] },
              "metric_value": {}
            }
          }
        },
        "suggestion": { "type": "string" },
        "evidence": { "type": "string" }
      }
    },
    "calibration_rule": {
      "type": "object",
      "required": ["id", "category", "severity", "current_thresholds", "population"],
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string", "enum": ["warn", "hard"] },
        "current_thresholds": { "type": "object" },
        "population": { "type": "integer" },
        "distribution": {
          "type": "object",
          "properties": {
            "min": { "type": "number" },
            "p25": { "type": "number" },
            "p50": { "type": "number" },
            "p75": { "type": "number" },
            "p90": { "type": "number" },
            "p95": { "type": "number" },
            "p99": { "type": "number" },
            "max": { "type": "number" }
          }
        },
        "violations_at_current": { "type": "object" },
        "candidate_thresholds": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["percentile", "value", "violations_above"],
            "properties": {
              "percentile": { "type": "string" },
              "value": { "type": "integer" },
              "violations_above": { "type": "integer" }
            }
          }
        },
        "error": { "type": ["string", "null"] }
      }
    }
  }
}
